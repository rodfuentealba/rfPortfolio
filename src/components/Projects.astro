---
import { getCollection } from "astro:content";
import Figma from "./icons/Figma.astro";
import Notion from "./icons/Notion.astro";
import React from "./icons/React.astro";
import Ant from "./icons/Ant.astro";
import Bootstrap from "./icons/Bootstrap.astro";
import Vue from "./icons/Vue.astro";
import LinkButton from "./LinkButton.astro";
import Link from "./icons/Link.astro";
import Claude from "./icons/Claude.astro";
import Lovable from "./icons/Lovable.astro";
import CodeIcon from '../components/icons/Code.astro';
import Date from './icons/Date.astro';
import Illustrator from "./icons/Illustrator.astro";

const allWorks = await getCollection('works')

const workOrder = ['wasteOlas', 'notarisa', 'wallet', 'autorisa', 'riivi'];
const works = allWorks.sort((a, b) => {
    const indexA = workOrder.indexOf(a.slug);
    const indexB = workOrder.indexOf(b.slug);
    return indexA - indexB;
});

const lang = Astro.url.pathname.startsWith('/en') ? 'en' : 'es';
const { t } = Astro.props;


const TAGS = {
    FIGMA: {
        name: "Figma",
        class: "bg-pink-200 text-pink-400 dark:bg-pink-100 dark:text-pink-800",
        icon: Figma,
    },
    LOVABLE: {
        name: "Lovable",
        class: "bg-violet-200 text-violet-800 dark:bg-violet-100 dark:text-violet-900",
        icon: Lovable,
    },
    CLAUDE: {
        name: "Claude",
        class: "bg-amber-200 text-amber-800 dark:bg-amber-100 dark:text-amber-900",
        icon: Claude,
    },
    AI: {
        name: "Illustrator",
        class: "bg-orange-200 text-orange-600 dark:bg-orange-100 dark:text-orange-700",
        icon: Illustrator,
    },
    REACT: {
        name: "React",
        class: "bg-cyan-100 text-cyan-600 dark:bg-cyan-900 dark:text-cyan-300",
        icon: React,
    },
    ANT: {
        name: "AntDesign",
        class: "bg-blue-100 text-blue-400 dark:bg-blue-900 dark:text-blue-300",
        icon: Ant,
    },
    BOOTSTRAP: {
        name: "Bootstrap",
        class: "bg-purple-100 text-purple-500 dark:bg-purple-300 dark:text-purple-800",
        icon: Bootstrap,
    },
    VUE: {
        name: "Vue",
        class: "bg-green-100 text-green-800 dark:bg-green-300 dark:text-green-700",
        icon: Vue,
    },
    NOTION: {
        name: "Notion",
        class: "bg-slate-300 text-green-800 dark:bg-slate-100 dark:text-slate-700",
        icon: Notion,
    },
};

---

<h2 class="text-2xl font-semibold mb-10 flex gap-x-2 items-center">
    <CodeIcon class="size-6"/>
    {t.title}
</h2>

<div class="flex flex-col md:grid md:grid-cols-2 gap-8">
    {
        works.map(work => {
            const {slug, data } = work
            const { titleProduct, img, link, tags } = data
            
            const titleDescription = lang === 'en' ? (data.titleDescription_en ?? data.titleDescription) : data.titleDescription
            const time = lang === 'en' ? (data.time_en ?? data.time) : data.time
            const description = lang === 'en' ? (data.description_en ?? data.description) : data.description

            return (
                <article class="flex flex-col group">
                    <div class="w-full">
                        <div class="relative flex flex-col items-center col-span-6 row-span-5 transition duration-500 ease-in-out transform hover:shadow-xl overflow-clip rounded-xl md:group-hover:-translate-y-1 lg:hover:bg-gray-800/50">
                        <img
                            alt={titleDescription}
                            class="object-cover object-top w-full h-full transition duration-500 md:group-hover:scale-110"
                            loading="lazy"
                            src={img}
                            />
                        </div>
                    </div>

                    <div class="w-full">
                    
                        <h3 class="mt-6 text-2xl font-bold text-gray-800 dark:text-gray-100">
                            {titleProduct} {titleDescription}
                        </h3>
                        
                        <h4 class="flex items-center my-2 text-sm text-gray-500 dark:text-gray-100 cursor-pointer">
                            <span class="flex items-center bg-gray-100 text-gray-800 text-xs font-medium me-2 px-3 py-1 rounded-sm dark:bg-gray-700 dark:text-gray-300">
                                <Date class="size-5 mr-1"/>
                                {lang === 'en' ? 'Time: Around' : 'Tiempo: Alrededor de'} {time}
                            </span>
                        </h4>

                        <div class="flex flex-wrap mt-2">
                            <ul class="flex flex-row mb-2 gap-x-2 cursor-pointer">
                                {tags.map((tagKey) => {
                                    const tag = TAGS[tagKey as keyof typeof TAGS];
                                    if (!tag) return null; // 🛡️ se salta los que no están definidos

                                    const Icon = tag.icon;

                                    return (
                                    <li>
                                        <span
                                        class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 hover:scale-105`}
                                        >
                                        <Icon class="size-4" />
                                        {tag.name}
                                        </span>
                                    </li>
                                    );
                                })}
                            </ul>

                            <div class="mt-2 text-gray-700 dark:text-gray-400">
                                {description}
                            </div>
                            <footer class="flex items-end justify-start mt-4 gap-x-4">
                                {link && (
                                    <LinkButton href={link}>
                                    {/* <LinkButton href={`/projects/${slug}`}></LinkButton> */}
                                        <Link class="size-4" />
                                        {t.more}
                                    </LinkButton>
                                )}
                            </footer>
                        </div>
                    </div>
                </article>
            )
        })
    }
</div>
