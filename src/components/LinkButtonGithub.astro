---
const { href } = Astro.props;
---

<a target="_blank" href={href}
role="link" class="inline-flex bg-gray-900 text-white border-gray-700 items-center
justify-center gap-2 px-3 py-2 space-x-2 text-base transition border dark:bg-white
dark:text-gray-900 dark:border-gray-300 focus-visible:ring-yellow-500/80 text-md hover:bg-black
hover:border-black group max-w-fit rounded-xl focus:outline-none focus-visible:outline-none
focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:bg-black"
>
<slot />
